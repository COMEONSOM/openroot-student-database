# ================================================================
#  .env.example  —  Student Database System  (Flask / MySQL)
# ================================================================

# ── Flask ────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# Generate your own with:
# python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── MySQL ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=REPLACE_WITH_YOUR_MYSQL_USERNAME
DB_PASSWORD=REPLACE_WITH_YOUR_MYSQL_PASSWORD
DB_NAME=REPLACE_WITH_YOUR_DATABASE_NAME

# TLS cert path — leave blank for local dev
# DB_SSL_CA=/path/to/ca-cert.pem

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5000

# ── Rate Limiting ────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0